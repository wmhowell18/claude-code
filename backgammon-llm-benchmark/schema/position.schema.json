{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://backgammon-llm-benchmark/schema/position.schema.json",
  "title": "Position record",
  "description": "A single benchmark position with redundant representations (PLAN.md §1.1). One JSON record is the source of truth for both text and image tracks. STUB: fields are indicative, not final.",
  "type": "object",
  "required": ["position_id", "xgid", "board_json", "ascii", "tier", "decision_type"],
  "properties": {
    "position_id": {
      "type": "string",
      "description": "Stable internal id (typically derived from the normalized XGID hash)."
    },
    "xgid": {
      "type": "string",
      "description": "Canonical XGID string; primary key and dedup source (PLAN.md §1.1)."
    },
    "gnubg_id": {
      "type": "object",
      "description": "Secondary ID for GNU BG interop (PLAN.md §1.1).",
      "properties": {
        "position_id": { "type": "string" },
        "match_id": { "type": "string" }
      }
    },
    "board_json": {
      "type": "object",
      "description": "Unambiguous machine-readable board, always from the player-to-move's perspective (PLAN.md §1.1).",
      "required": ["points", "bar", "off", "turn", "cube", "score", "decision_type"],
      "properties": {
        "points": {
          "type": "array",
          "description": "Indices 1-24 from mover's perspective; positive = mover (x), negative = opponent (o).",
          "items": { "type": "integer" },
          "minItems": 26,
          "maxItems": 26
        },
        "bar": {
          "type": "object",
          "properties": { "x": { "type": "integer" }, "o": { "type": "integer" } }
        },
        "off": {
          "type": "object",
          "properties": { "x": { "type": "integer" }, "o": { "type": "integer" } }
        },
        "turn": { "type": "string", "enum": ["x", "o"] },
        "dice": {
          "type": "array",
          "description": "The roll to be played (checker decisions); empty/absent for cube decisions.",
          "items": { "type": "integer", "minimum": 1, "maximum": 6 }
        },
        "cube": {
          "type": "object",
          "properties": {
            "value": { "type": "integer" },
            "owner": { "type": "string", "enum": ["center", "x", "o"] }
          }
        },
        "score": {
          "type": "object",
          "properties": {
            "x": { "type": "integer" },
            "o": { "type": "integer" },
            "length": { "type": "integer", "description": "Match length; 0 or absent for money play." },
            "crawford": { "type": "boolean" }
          }
        },
        "pip": {
          "type": "object",
          "properties": { "x": { "type": "integer" }, "o": { "type": "integer" } }
        },
        "decision_type": { "type": "string", "enum": ["checker", "cube"] }
      }
    },
    "ascii": {
      "type": "string",
      "description": "Deterministic fixed-width ASCII render (text-track payload)."
    },
    "ascii_render_version": { "type": "string" },
    "image_png": {
      "type": "string",
      "description": "Path/ref to rendered PNG (image-track payload); may be absent for held-out."
    },
    "image_svg": {
      "type": "string",
      "description": "Path/ref to source SVG for deterministic re-rasterization."
    },
    "image_render_version": { "type": "string" },
    "decision_type": { "type": "string", "enum": ["checker", "cube"] },
    "play_mode": { "type": "string", "enum": ["money", "match"] },
    "tier": { "type": "string", "enum": ["T1", "T2", "T3", "T4"] },
    "phase": {
      "type": "string",
      "enum": ["race", "holding-game", "blitz", "priming", "backgame", "bearoff", "opening-ish", "cube-action"]
    },
    "split": { "type": "string", "enum": ["pilot", "dev", "heldout"] },
    "rollout_ref": {
      "type": "string",
      "description": "Reference/key into rollouts/ ground-truth data for this position."
    },
    "canary": {
      "type": "string",
      "description": "Embedded canary token (BENCH-CANARY-<uuid>) for published artifacts (PLAN.md §2.5)."
    },
    "created": { "type": "string", "format": "date-time" }
  }
}
